# Não é necessário criar um .env para rodar via Docker — o backend/Dockerfile
# gera o .env automaticamente no build com as configurações abaixo, e roda
# `php artisan key:generate --force` para popular APP_KEY.
#
# Este arquivo serve apenas se você for rodar o backend FORA do Docker (PHP
# nativo na máquina hospedeira). Nesse caso, copie para `.env` e rode:
#
#   cp .env.example .env
#   php artisan key:generate
#   touch database/database.sqlite
#   php artisan migrate --force
#   php artisan app:seed
#   php artisan serve

APP_NAME=InterlinkedLog
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=sqlite

# As migrations atuais não criam tabelas para cache/session/queue em banco,
# então use file/sync para evitar SQLSTATE "no such table".
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
