# Não é necessário criar um .env para rodar via Docker — o docker-compose.yml já
# injeta VITE_API_URL=http://backend:8000 no container do frontend.
#
# Este arquivo serve apenas se você for rodar o frontend FORA do Docker (bun dev
# na máquina hospedeira). Nesse caso, copie para `.env`:
#
#   cp .env.example .env
#
# E aponte para onde o backend está acessível:
VITE_API_URL=http://localhost:8080
